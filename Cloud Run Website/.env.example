# Copy to release_agent/.env for local development. Never commit real values.

# GCP resource identifiers (defaults already match the production dataset;
# override only for local testing against a different project).
PULSE_PROJECT=sprinternship-aus-2026
PULSE_DATASET=release_notes
PULSE_TABLE=notes
PULSE_BQ_LOCATION=US

# Model + app identity
PULSE_MODEL=gemini-3.6-flash
PULSE_APP_NAME=pulse-release-agent

# Vertex AI mode for the Gemini model (required in Cloud Run / production).
# gemini-3.6-flash is GLOBAL-endpoint only — verified live: global -> 200,
# us-central1 -> 404 NOT_FOUND. Do not change this to a region unless the
# configured model is confirmed available there (probe first).
GOOGLE_GENAI_USE_VERTEXAI=True
GOOGLE_CLOUD_PROJECT=sprinternship-aus-2026
GOOGLE_CLOUD_LOCATION=global



# GCP Service Health feed (public, no auth required)
PULSE_STATUS_URL=https://status.cloud.google.com/incidents.json
PULSE_STATUS_TTL_SECONDS=300

# Cloud Run runtime service account
PULSE_SERVICE_ACCOUNT=aus-sprinternship-2026-sa@sprinternship-aus-2026.iam.gserviceaccount.com

# Optional: Vertex AI Search engine ID for semantic search. Leave blank to
# disable semantic search gracefully (structured search still works).
PULSE_VERTEX_ENGINE_ID=

# Local ADC — point at a service account key when not using `gcloud auth
# application-default login`. Leave unset when running on Cloud Run.
GOOGLE_APPLICATION_CREDENTIALS=
